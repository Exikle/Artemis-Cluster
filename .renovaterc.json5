{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "github>home-operations/renovate-presets#2.1.0",
    ":automergePr",
    ":timezone(America/Toronto)",
  ],
  suppressNotifications: ["prEditedNotification", "prIgnoreNotification"],
  // platformCommit: use Forgejo API so server signs commits
  platformCommit: "enabled",
  schedule: ["at any time"],
  packageRules: [
    {
      description: "Disable artifact actions v4+ — incompatible with Forgejo",
      matchManagers: ["github-actions"],
      matchPackageNames: ["actions/upload-artifact", "actions/download-artifact"],
      enabled: false,
    },
    // Auto-merge
    {
      description: "Auto-merge all container digests",
      matchDatasources: ["docker"],
      automerge: true,
      matchUpdateTypes: ["digest"],
      ignoreTests: false,
    },
    {
      description: "Auto-merge OCI Charts",
      matchDatasources: ["docker"],
      automerge: true,
      matchUpdateTypes: ["minor", "patch"],
      matchPackageNames: ["/kube-prometheus-stack/"],
      schedule: ["before 6am on Monday"],
      ignoreTests: false,
    },
    {
      description: "Auto-merge Forgejo Actions",
      matchManagers: ["github-actions"],
      automerge: true,
      matchUpdateTypes: ["minor", "patch", "digest"],
      minimumReleaseAge: "3 days",
      ignoreTests: true,
    },
    {
      description: "Auto-merge trusted Forgejo Actions",
      matchManagers: ["github-actions"],
      matchPackageNames: ["/^actions\\//", "/^renovatebot\\//"],
      automerge: true,
      matchUpdateTypes: ["minor", "patch", "digest"],
      minimumReleaseAge: "1 minute",
      ignoreTests: true,
    },
    {
      description: "Auto-merge Grafana dashboards",
      matchDatasources: ["custom.grafana-dashboards"],
      matchUpdateTypes: ["major"],
      automerge: true,
      automergeType: "branch",
      ignoreTests: true,
    },
    {
      description: "Auto-merge all patch updates",
      matchUpdateTypes: ["patch"],
      automerge: true,
      ignoreTests: false,
    },
    {
      description: "Auto-merge all minor updates",
      matchUpdateTypes: ["minor"],
      automerge: true,
      ignoreTests: false,
    },
    // Groups
    {
      description: "Flux Operator Group",
      groupName: "flux-operator",
      matchDatasources: ["docker"],
      matchPackageNames: ["/flux-operator/", "/flux-instance/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "Rook-Ceph Group",
      groupName: "rook-ceph",
      matchDatasources: ["docker", "helm"],
      matchPackageNames: ["/rook-ceph/", "/rook-ceph-cluster/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "Kubernetes Group",
      groupName: "kubernetes",
      matchDatasources: ["docker"],
      matchPackageNames: [
        "/siderolabs\\/kubelet/",
        "/kube-apiserver/",
        "/kube-controller-manager/",
        "/kube-scheduler/",
      ],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "Cilium Group",
      groupName: "cilium",
      matchDatasources: ["docker"],
      matchPackageNames: ["/cilium\\/charts\\/cilium/", "/charts-mirror\\/cilium/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "Envoy Gateway Group",
      groupName: "envoy-gateway",
      matchDatasources: ["docker"],
      matchPackageNames: ["/envoyproxy\\/gateway-helm/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    {
      description: "Toolhive Group",
      groupName: "toolhive",
      matchDatasources: ["docker"],
      matchPackageNames: ["/toolhive-operator/"],
      group: {
        commitMessageTopic: "{{{groupName}}} group",
      },
      minimumGroupSize: 2,
    },
    // Labels
    {
      description: "Label major updates",
      matchUpdateTypes: ["major"],
      addLabels: ["type/major", "priority/high"],
    },
    {
      description: "Label minor updates",
      matchUpdateTypes: ["minor"],
      addLabels: ["type/minor", "priority/medium"],
    },
    {
      description: "Label patch updates",
      matchUpdateTypes: ["patch"],
      addLabels: ["type/patch", "priority/low"],
    },
    {
      description: "Label digest updates",
      matchUpdateTypes: ["digest"],
      addLabels: ["type/digest"],
    },
    {
      description: "Label container updates",
      matchDatasources: ["docker"],
      addLabels: ["renovate/container"],
    },
    {
      description: "Label Helm updates",
      matchDatasources: ["helm"],
      addLabels: ["renovate/helm"],
    },
    {
      description: "Label GitHub Release updates",
      matchDatasources: ["github-releases", "github-tags"],
      addLabels: ["renovate/github-release"],
    },
    {
      description: "Label Forgejo Actions updates",
      matchManagers: ["github-actions"],
      addLabels: ["renovate/forgejo-action"],
    },
  ],
}
