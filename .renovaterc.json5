{
  $schema: "https://docs.renovatebot.com/renovate-schema.json",
  extends: [
    "config:recommended",
    "docker:enableMajor",
    "helpers:pinGitHubActionDigests",
    "local>exikle/Artemis-Cluster//.renovate/autoMerge.json5",
    "local>exikle/Artemis-Cluster//.renovate/changelogs.json5",
    "local>exikle/Artemis-Cluster//.renovate/customManagers.json5",
    "local>exikle/Artemis-Cluster//.renovate/grafanaDashboards.json5",
    "local>exikle/Artemis-Cluster//.renovate/groups.json5",
    "local>exikle/Artemis-Cluster//.renovate/labels.json5",
    "local>exikle/Artemis-Cluster//.renovate/overrides.json5",
    "local>exikle/Artemis-Cluster//.renovate/semanticCommits.json5",
    "local>exikle/Artemis-Cluster//.renovate/talosFactory.json5",
    ":automergeBranch",
    ":disableRateLimiting",
    ":dependencyDashboard",
    ":semanticCommits",
    ":timezone(America/Toronto)"
  ],
  dependencyDashboardTitle: "Renovate Dashboard 🤖",
  suppressNotifications: ["prEditedNotification", "prIgnoreNotification"],
  schedule: ["every weekday"],
  automergeSchedule: ["every weekday"],
  ignorePaths: ["**/*.secret.*", "**/resources/**"],
  flux: {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"]
  },
  "helm-values": {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"]
  },
  kubernetes: {
    managerFilePatterns: ["/\\.yaml(?:\\.j2)?$/"]
  }
}
