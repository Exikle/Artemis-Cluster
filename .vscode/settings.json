{
  "editor.bracketPairColorization.enabled": true,
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "editor.fontFamily": "FiraCode Nerd Font",
  "editor.fontLigatures": true,
  "editor.fontSize": 14,
  "editor.formatOnSave": true,
  "editor.guides.bracketPairs": true,
  "editor.guides.bracketPairsHorizontal": true,
  "editor.guides.highlightActiveBracketPair": true,
  "editor.hover.delay": 1500,
  "editor.rulers": [100],
  "editor.stickyScroll.enabled": false,
  "explorer.autoReveal": true,
  "files.associations": {
    "**/*.json5": "json5",
    "*.yaml.j2": "jinja-yaml"
  },
  "files.trimTrailingWhitespace": true,
  "material-icon-theme.files.associations": {
    "*.gotmpl": "smarty",
    "*.just": "just",
    "*.yaml.j2": "jinja",
    "helmfile.yaml": "helm",
    "kubeconfig": "kubernetes",
    "talosconfig": "kubernetes"
  },
  "material-icon-theme.folders.associations": {
    ".archive": "archive",
    ".forgejo/workflows": "ci",
    ".private": "archive",
    ".renovate": "robot",
    "actions-runner-system": "github",
    "ai": "robot",
    "bootstrap": "seeders",
    "bootstrap/helmfile.d": "helm",
    "cert-manager": "guard",
    "cilium": "connection",
    "configs": "config",
    "controllers": "controller",
    "coredns": "connection",
    "database": "database",
    "default": "home",
    "democratic-csi": "database",
    "dev": "development",
    "external-dns": "connection",
    "external-secrets": "secure",
    "external-services": "connection",
    "flux": "pipe",
    "flux-system": "pipe",
    "flux-tools": "tools",
    "gaming": "console",
    "helm": "helm",
    "helmchart": "helm",
    "helmcharts": "helm",
    "home-automation": "home",
    "k8s": "kubernetes",
    "kube-system": "kubernetes",
    "kubernetes": "kubernetes",
    "media": "video",
    "metallb-system": "connection",
    "monitoring": "event",
    "network": "connection",
    "networking": "connection",
    "observability": "event",
    "openebs-system": "base",
    "operators": "robot",
    "rook-ceph": "dump",
    "security": "guard",
    "storage": "database",
    "system-upgrade": "update",
    "talos": "linux",
    "templates": "template",
    "tools": "tools",
    "traefik": "connection",
    "volsync": "backup",
    "volsync-system": "aws"
  },
  "prettier.documentSelectors": ["**/*.md", "**/*.json", "**/*.js", "**/*.ts", "**/*.json5"],
  "terminal.integrated.fontSize": 14,
  "vs-kubernetes": {
    "vs-kubernetes.kubeconfig": "/home/exikle/.kube/config",
    "vs-kubernetes.knownKubeconfigs": ["/home/exikle/.kube/config"]
  },
  "window.zoomLevel": 0,
  "yaml.schemaStore.enable": false,
  "yaml.validate": false,
  "yaml.schemas": {},
  "[jinja-yaml]": {
    "editor.formatOnSave": false
  },
  "[just]": {
    "editor.defaultFormatter": "nefrob.vscode-just-syntax"
  },
  "[markdown]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
    "editor.tabSize": 4
  },
  "[yaml]": {
    "editor.defaultFormatter": "bluebrown.yamlfmt"
  }
}
