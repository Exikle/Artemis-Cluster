{
  "mem0": {
    "llm": {
      "provider": "openai",
      "config": {
        "model": "mistral:7b-instruct",
        "temperature": 0.1,
        "max_tokens": 2000,
        "api_key": "env:OPENAI_API_KEY",
        "openai_base_url": "http://ollama.dcunha.io:11434/v1"
      }
    },
    "embedder": {
      "provider": "openai",
      "config": {
        "model": "nomic-embed-text",
        "api_key": "env:OPENAI_API_KEY",
        "openai_base_url": "http://ollama.dcunha.io:11434/v1",
        "embedding_dims": 768
      }
    },
    "vector_store": {
      "provider": "qdrant",
      "config": {
        "collection_name": "openmemory",
        "url": "env:QDRANT_URL",
        "api_key": "env:QDRANT_API_KEY",
        "embedding_model_dims": 768
      }
    }
  }
}
